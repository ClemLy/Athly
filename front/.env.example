# ================================
# API
# ================================
# URL de votre backend Athly
# En développement local : remplacez par votre IP sur le réseau local
# (pas "localhost" — React Native sur téléphone physique ne peut pas le résoudre)
API_URL=http://VOTRE_IP_LOCALE:4000/api


# ================================
# JWT & AUTH
# ================================
# Clé utilisée pour stocker le token JWT dans Expo SecureStore
TOKEN_KEY=athly_token


# ================================
# CONFIG APP
# ================================
# development | production
APP_ENV=development
