{
  "cli": {
    "version": ">= 16.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "production": {
      "android": {
        "buildType": "apk"
      },
      "env": {
        "API_URL": "https://athly-api.onrender.com",
        "TOKEN_KEY": "athly_token",
        "APP_ENV": "production"
      }
    }
  }
}
