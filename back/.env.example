# ------------------------------
# 🔧 Configuration serveur
# ------------------------------
PORT=4000


# ------------------------------
# 🗄️ Base de données MongoDB
# ------------------------------
# Connection string MongoDB Atlas ou local
# Exemple Atlas : mongodb+srv://username:password@cluster.mongodb.net/athly
# Exemple local : mongodb://localhost:27017/athly
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/athly


# ------------------------------
# 🔐 JWT (authentification)
# ------------------------------
# Clé secrète longue et aléatoire — générer avec :
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=VOTRE_JWT_SECRET_TRES_LONG_ET_ALEATOIRE


# ------------------------------
# ⏳ Durée de validité des tokens
# ------------------------------
# Exemples : 1h, 2d, 7d, 30m
JWT_EXPIRES_IN=1d


# ------------------------------
# 🚨 (Optionnel) Refresh Token
# ------------------------------
# Utile uniquement si vous implémentez un système de refresh token
REFRESH_TOKEN_SECRET=
REFRESH_TOKEN_EXPIRES_IN=7d


# ------------------------------
# 📨 Email / SMTP  (Brevo)
# ------------------------------
# Utilisé pour envoyer les codes OTP (vérification email, reset password)
SMTP_HOST=smtp-relay.brevo.com
# Port 587 en dev (STARTTLS) — port 2525 si 587 est bloqué sur le réseau
SMTP_PORT=587
# Credential d'authentification Brevo (onglet SMTP & API de ton compte)
SMTP_USER=votre_login@smtp-brevo.com
# Clé SMTP générée dans Brevo (SMTP & API > Generate a new SMTP key)
SMTP_PASS=VOTRE_CLE_SMTP_BREVO
# Adresse d'expédition — doit être un expéditeur vérifié dans Brevo
# (Brevo dashboard > Senders & IPs > Add a sender)
# ⚠️  Différent de SMTP_USER — c'est l'adresse visible par le destinataire
SMTP_FROM=votre.adresse.verifiee@domaine.com


# ------------------------------
# 🧪 Environnement
# ------------------------------
# development | production
NODE_ENV=development
